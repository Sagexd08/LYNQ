# Database
DATABASE_URL=postgresql://user:password@localhost:5432/lynq

# Redis Cache
REDIS_URL=redis://localhost:6379/0

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=lynq-credit-scoring

# Model Configuration
MODEL_VERSION=v1.0.0
MODEL_PATH=./models/production
SYNTHETIC_DATA_SIZE=100000
SYNTHETIC_DEFAULT_RATE=0.15

# API Configuration
API_HOST=0.0.0.0
API_PORT=8001
API_WORKERS=4

# Monitoring
LOG_LEVEL=INFO
ENABLE_MONITORING=true
