# Ethereum Network RPC URLs (standardized)
ETHEREUM_SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY

# Celo RPC URLs
# Alfajores (testnet)
CELO_ALFAJORES_RPC_URL=https://alfajores-forno.celo-testnet.org
# Celo (mainnet)
CELO_RPC_URL=https://forno.celo.org

# Backwards-compatible (legacy names)
# SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
# MAINNET_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY

# Deployment Account Private Key (preferred)
PRIVATE_KEY=your_private_key_here

# Mnemonic-based deployments (disabled by default)
# MNEMONIC="word1 word2 ... word12/24"
# USE_MNEMONIC=1

# Optional safety check: fail deployment if the derived deployer address is not this value
# EXPECTED_DEPLOYER_ADDRESS=0xa025505514a057d9f7d9aa6992e0f30fa5072071

# Etherscan API Key for Contract Verification
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Celoscan API Key for Contract Verification (optional)
CELOSCAN_API_KEY=your_celoscan_api_key_here

# Liquidator Configuration
LIQUIDATOR_BOND_AMOUNT=100
AUCTION_DURATION_HOURS=24
INITIAL_PRICE_DECAY_PERCENT=2

# Contract Addresses (after deployment)
USDC_ADDRESS=0x0000000000000000000000000000000000000000
LIQUIDATOR_PROTOCOL_ADDRESS=0x0000000000000000000000000000000000000000
