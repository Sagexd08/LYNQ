{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node", "hardhat"],
    "skipLibCheck": true
  },
  "include": ["hardhat-env.d.ts", "scripts*.ts", "test*.ts"],
  "exclude": ["node_modules", "artifacts", "cache", "deployments"]
}
