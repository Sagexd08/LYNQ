# Frontend environment variables (Vite)

# Backend base URL (Nest global prefix `api/v1`)
VITE_API_BASE_URL=http://localhost:3000/api/v1

# App metadata
VITE_APP_NAME=LYNQ
VITE_APP_VERSION=dev

# Optional additional backend URL reference
# VITE_BACKEND_URL=http://localhost:3000

# Feature flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ERROR_REPORTING=false
VITE_ENABLE_DEBUG=false

# Particle (placeholder values)
VITE_PARTICLE_PROJECT_ID=your_particle_project_id
VITE_PARTICLE_CLIENT_KEY=your_particle_client_key
VITE_PARTICLE_APP_ID=your_particle_app_id

# Network selection
VITE_DEFAULT_NETWORK=testnet

# Optional module address (hex)
# VITE_MODULE_ADDRESS=

# Telegram integration (optional)
# VITE_TELEGRAM_BOT_TOKEN=
# VITE_TELEGRAM_DEFAULT_CHAT_ID=