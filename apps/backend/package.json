{
  "name": "@lynq/backend",
  "version": "1.0.0",
  "description": "Backend API for LYNQ lending platform",
  "main": "dist/main.js",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "jest --runInBand --testPathPattern=e2e-spec",
    "lint": "eslint .",
    "format": "prettier --write \"src*.{ts,json}\"",
    "migration:generate": "ts-node --project tsconfig.json ./node_modules/typeorm/cli.js migration:generate -d typeorm.datasource.ts",
    "migration:run": "ts-node --project tsconfig.json ./node_modules/typeorm/cli.js migration:run -d typeorm.datasource.ts",
    "migration:revert": "ts-node --project tsconfig.json ./node_modules/typeorm/cli.js migration:revert -d typeorm.datasource.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.11",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.11",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.11",
    "@nestjs/schedule": "^6.1.0",
    "@nestjs/swagger": "^11.2.3",
    "@sentry/node": "^8.55.0",
    "@supabase/supabase-js": "^2.89.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "decimal.js": "^10.6.0",
    "dotenv": "^16.6.1",
    "ethers": "^6.16.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.2",
    "passport": "^0.7.0",
    "passport-custom": "^1.1.1",
    "passport-jwt": "^4.0.1",
    "prom-client": "^14.2.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "telegraf": "^4.16.3",
    "winston": "^3.19.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@chainlink/contracts": "^1.5.0",
    "@nestjs/cli": "^11.0.14",
    "@nestjs/testing": "^11.1.11",
    "@nestjs/throttler": "^6.5.0",
    "@types/bcrypt": "^5.0.2",
    "@types/decimal.js": "^7.4.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.3",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "eslint": "^9.39.2",
    "jest": "^29.7.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "optionalDependencies": {
    "@next/swc-win32-x64-msvc": "^14.2.33"
  },
  "pnpm": {
    "overrides": {
      "@openzeppelin/contracts-upgradeable@>=4.3.0 <4.8.3": ">=4.8.3",
      "@openzeppelin/contracts-upgradeable@>=4.0.0 <4.9.3": ">=4.9.3",
