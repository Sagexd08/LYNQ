{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "types": ["jest", "node"],
    "outDir": "./dist-test",
    "baseUrl": "."
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts",
    "test/**/*.spec.ts",
    "test/**/*.e2e-spec.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "dist-test"
  ]
}